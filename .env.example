# Copy to .env and customize. Never commit .env.
# All keys are read by common/config.py:Settings with prefix LLMEVAL_.

# --- Model / serving ---
LLMEVAL_MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
LLMEVAL_VLLM_HOST=127.0.0.1
LLMEVAL_VLLM_PORT=8000
LLMEVAL_VLLM_TIMEOUT_S=120
LLMEVAL_VLLM_MAX_RETRIES=3
# vLLM's OpenAI-compatible server requires a bearer token string; default "EMPTY" is fine.
LLMEVAL_VLLM_API_KEY=EMPTY

# --- vLLM server tunables (all optional) ---
# LLMEVAL_VLLM_MAX_MODEL_LEN=4096
# LLMEVAL_VLLM_DTYPE=auto      # auto | float16 | bfloat16 | float32
# LLMEVAL_VLLM_GPU_MEMORY_UTILIZATION=0.9
# LLMEVAL_VLLM_TENSOR_PARALLEL_SIZE=1
# LLMEVAL_VLLM_MAX_NUM_SEQS=256
# LLMEVAL_VLLM_TRUST_REMOTE_CODE=false
# LLMEVAL_VLLM_DOWNLOAD_DIR=

# --- Paths ---
LLMEVAL_CACHE_DIR=.cache
LLMEVAL_RESULTS_DIR=results

# --- Logging ---
LLMEVAL_LOG_LEVEL=INFO
# "console" for dev, "json" for production / CI
LLMEVAL_LOG_FORMAT=console

# --- Determinism ---
LLMEVAL_SEED=42

# --- Mock backend (for local dev without a GPU) ---
LLMEVAL_MOCK_BACKEND=false

# --- Optional: HuggingFace auth for gated models ---
# HF_TOKEN=
